# Domain
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@example.com

# Zitadel — copy from your Zitadel instance's OIDC endpoints
ZITADEL_ISSUER=https://your-instance.us1.zitadel.cloud
ZITADEL_AUTH_URL=https://your-instance.us1.zitadel.cloud/oauth/v2/authorize
ZITADEL_TOKEN_URL=https://your-instance.us1.zitadel.cloud/oauth/v2/token
ZITADEL_JWKS_URL=https://your-instance.us1.zitadel.cloud/oauth/v2/keys
ZITADEL_MCP_CLIENT_ID=your-mcp-app-client-id

# Logging (prod defaults — override if needed)
#LOG_FORMAT=json
#LOG_LEVEL=info
#LOG_DETAILED=false

# Service ports (prod defaults — override if needed)
#AUTH_PORT=8080
#TASKS_PORT=8080
